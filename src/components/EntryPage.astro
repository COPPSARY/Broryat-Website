---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SEO, SITE, UI, formatDate, type Locale } from "../data/site";
import { localizePath } from "../data/site";
import type { MarkdownTutorial, SiteArticle } from "../lib/content";

interface Props {
  locale: Locale;
  collection: "articles" | "tutorials";
  entry: SiteArticle | MarkdownTutorial;
  alternateLocaleHref: string;
}

const { locale, collection, entry, alternateLocaleHref } = Astro.props;
const ui = UI[locale];
const isDbArticle = !("data" in entry);
const Content = isDbArticle ? null : entry.Content;
const isArticle = collection === "articles";
const articleEntry = isArticle ? (entry as SiteArticle) : null;
const tutorialEntry = isArticle ? null : (entry as MarkdownTutorial);
const data = isDbArticle ? entry : entry.data;

const coverImageURL = new URL(data.coverImage, Astro.site).href;
const pageURL = new URL(Astro.url.pathname, Astro.site).href;

const structuredData = {
  "@type": isArticle ? "TechArticle" : "HowTo",
  headline: data.title,
  name: data.title,
  description: data.description,
  image: coverImageURL,
  inLanguage: SEO.ogLocale[locale],
  mainEntityOfPage: pageURL,
  author: { "@type": "Organization", name: "Sayana Studio" },
  publisher: { "@id": `${SEO.siteUrl}/#organization` },
  ...(articleEntry
    ? { datePublished: ("data" in articleEntry ? articleEntry.data.date : articleEntry.date).toISOString() }
    : {}),
};
---

<BaseLayout
  locale={locale}
  title={`${data.title} | ${SITE.name}`}
  description={data.description}
  alternateLocaleHref={alternateLocaleHref}
  ogType="article"
  ogImage={data.coverImage}
  publishedTime={articleEntry ? ("data" in articleEntry ? articleEntry.data.date : articleEntry.date).toISOString() : undefined}
  section={articleEntry ? ("data" in articleEntry ? articleEntry.data.tag : articleEntry.tag) : ui.tutorialLabel}
  structuredData={structuredData}
>
  <main class="shell entry-page">
    <a class="back-link" href={localizePath(locale, collection)}>
      {isArticle ? ui.backToArticles : ui.backToTutorials}
    </a>

    <header class="entry-hero">
      <div class="entry-meta">
        <p class="eyebrow">
          <span class="tag">{articleEntry ? ("data" in articleEntry ? articleEntry.data.tag : articleEntry.tag) : ui.tutorialLabel}</span>
          {articleEntry && (
            <time datetime={("data" in articleEntry ? articleEntry.data.date : articleEntry.date).toISOString()}>
              {formatDate("data" in articleEntry ? articleEntry.data.date : articleEntry.date, locale)}
            </time>
          )}
        </p>
        <h1>{data.title}</h1>
        <p>{data.description}</p>
      </div>
      <img class="entry-cover" src={data.coverImage} alt="" />
    </header>

    {tutorialEntry && tutorialEntry.data.videoUrl && (
      <section class="tutorial-video">
        <video
          src={tutorialEntry.data.videoUrl}
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
        >
        </video>
      </section>
    )}

    {tutorialEntry && !tutorialEntry.data.videoUrl && (
      <section class="video-placeholder">
        <p class="eyebrow">{ui.videoComingSoon}</p>
        <h2>{ui.videoComingSoon}</h2>
        <p>{ui.videoPlaceholder}</p>
      </section>
    )}

    <article class="prose">
      {isDbArticle ? <Fragment set:html={entry.bodyHtml} /> : Content && <Content />}
    </article>
  </main>
</BaseLayout>
