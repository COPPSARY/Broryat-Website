---
import { formatDate, UI, type Locale } from "../data/site";
import { getEntryUrl } from "../lib/content";
import type { SiteArticle } from "../lib/content";

interface Props {
  locale: Locale;
  article: SiteArticle;
}

const { locale, article } = Astro.props;
const ui = UI[locale];
const data = "data" in article ? article.data : article;
---

<article class="content-card">
  <img src={data.coverImage} alt="" loading="lazy" />
  <div class="card-copy">
    <p class="eyebrow">
      <span class="tag">{data.tag}</span>
      <time datetime={data.date.toISOString()}>{formatDate(data.date, locale)}</time>
    </p>
    <h3>{data.title}</h3>
    <p>{data.description}</p>
    <a class="inline-link" href={getEntryUrl("articles", locale, data.translationId)}>
      {ui.readArticle}
    </a>
  </div>
</article>
