---
import EntryPage from "../../../components/EntryPage.astro";
import { getArticle } from "../../../lib/content";

export const prerender = false;

const entry = await getArticle("en", Astro.params.slug ?? "");

if (!entry) {
  return Astro.redirect("/en/articles/");
}

const translationId = "data" in entry ? entry.data.translationId : entry.translationId;
---

<EntryPage
  locale="en"
  collection="articles"
  entry={entry}
  alternateLocaleHref={`/articles/${translationId}/`}
/>
