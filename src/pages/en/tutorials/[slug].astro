---
import EntryPage from "../../../components/EntryPage.astro";
import { getTutorial } from "../../../lib/content";

export const prerender = false;

const entry = await getTutorial("en", Astro.params.slug ?? "");

if (!entry) {
  return Astro.redirect("/en/tutorials/");
}
---

<EntryPage
  locale="en"
  collection="tutorials"
  entry={entry}
  alternateLocaleHref={`/tutorials/${entry.data.translationId}/`}
/>
