---
import EntryPage from "../../components/EntryPage.astro";
import { getArticle } from "../../lib/content";

export const prerender = false;

const entry = await getArticle("kh", Astro.params.slug ?? "");

if (!entry) {
  return Astro.redirect("/articles/");
}

const translationId = "data" in entry ? entry.data.translationId : entry.translationId;
---

<EntryPage
  locale="kh"
  collection="articles"
  entry={entry}
  alternateLocaleHref={`/en/articles/${translationId}/`}
/>
