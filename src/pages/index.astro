---
import LandingPage from "../components/LandingPage.astro";
import { getLocalizedCollection } from "../lib/content";

const locale = "kh";
const latestArticles = (await getLocalizedCollection("articles", locale)).slice(0, 3);
const tutorials = await getLocalizedCollection("tutorials", locale);
---

<LandingPage
  locale={locale}
  latestArticles={latestArticles}
  tutorials={tutorials}
  alternateLocaleHref="/en/"
/>
