---
import LandingPage from "../components/LandingPage.astro";
import { getLocalizedArticles, getLocalizedCollection } from "../lib/content";
import { getEditableSiteSettings } from "../lib/server/siteSettings";

const locale = "kh";
const latestArticles = (await getLocalizedArticles(locale)).slice(0, 3);
const tutorials = await getLocalizedCollection("tutorials", locale);
const editableSettings = await getEditableSiteSettings(locale);
---

<LandingPage
  locale={locale}
  latestArticles={latestArticles}
  tutorials={tutorials}
  alternateLocaleHref="/en/"
  editableSettings={editableSettings}
/>
