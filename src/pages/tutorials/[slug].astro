---
import EntryPage from "../../components/EntryPage.astro";
import { getTutorial } from "../../lib/content";

export const prerender = false;

const entry = await getTutorial("kh", Astro.params.slug ?? "");

if (!entry) {
  return Astro.redirect("/tutorials/");
}
---

<EntryPage
  locale="kh"
  collection="tutorials"
  entry={entry}
  alternateLocaleHref={`/en/tutorials/${entry.data.translationId}/`}
/>
